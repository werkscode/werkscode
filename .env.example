# PostgreSQL
POSTGRES_USER=werkscode
POSTGRES_PASSWORD=werkscode
POSTGRES_DB=werkscode

# App database connection
DATABASE_URL=postgresql://werkscode:werkscode@localhost:5432/werkscode
NUXT_DATABASE_URL=postgresql://werkscode:werkscode@localhost:5432/werkscode

# Public app URL
NUXT_PUBLIC_APP_URL=http://localhost:3000

# Nitro / Node
NODE_ENV=development
NUXT_HOST=0.0.0.0
NUXT_PORT=3000

# Contact form — Resend (https://resend.com/domains)
# Dev: use onboarding@resend.dev as NUXT_CONTACT_FROM_EMAIL until werkscode.de is verified
NUXT_RESEND_API_KEY=
NUXT_CONTACT_FROM_EMAIL=onboarding@resend.dev
NUXT_CONTACT_NOTIFY_EMAIL=

# Contact admin inbox — bookmark /admin/messages (not linked in nav)
NUXT_CONTACT_ADMIN_TOKEN=
