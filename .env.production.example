# Production environment — copy to .env on the server only.
# Do not commit real values.
#
# Canonical public URL (SEO, OG images):
# NUXT_PUBLIC_APP_URL=https://werkscode.de
#
# Database host is `db` (Docker service name), not localhost:
# DATABASE_URL=postgresql://USER:PASSWORD@db:5432/werkscode
# NUXT_DATABASE_URL=postgresql://USER:PASSWORD@db:5432/werkscode

POSTGRES_USER=werkscode
POSTGRES_PASSWORD=
POSTGRES_DB=werkscode

DATABASE_URL=postgresql://werkscode:CHANGE_ME@db:5432/werkscode
NUXT_DATABASE_URL=postgresql://werkscode:CHANGE_ME@db:5432/werkscode

NUXT_PUBLIC_APP_URL=https://werkscode.de
NODE_ENV=production
