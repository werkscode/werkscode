# Staging environment — copy to .env and fill in values

POSTGRES_USER=werkscode
POSTGRES_PASSWORD=change-me-staging
POSTGRES_DB=werkscode

DATABASE_URL=postgresql://werkscode:change-me-staging@db:5432/werkscode
NUXT_DATABASE_URL=postgresql://werkscode:change-me-staging@db:5432/werkscode

NUXT_PUBLIC_APP_URL=https://staging.example.com
NODE_ENV=production

# Contact form (optional — same vars as production)
NUXT_RESEND_API_KEY=
NUXT_CONTACT_FROM_EMAIL=onboarding@resend.dev
NUXT_CONTACT_NOTIFY_EMAIL=
NUXT_CONTACT_ADMIN_TOKEN=
