NUXT_HOST=0.0.0.0
NUXT_PORT=3000

# STEP converter (pythonOCC). Docker compose sets NUXT_STEP_CONVERTER_URL automatically.
# NUXT_STEP_CONVERTER_URL=http://localhost:8000

# Persistence: when false/unset (public demo), setup/catalog/quotes/history use Pinia + localStorage
# in the browser (no Postgres needed for those). When true, they use PostgreSQL.
# Local clone: set true, or use docker-compose.dev.yml which enables it automatically.
# NUXT_PUBLIC_PERSISTENCE_ENABLED=true

# Local without Docker (Postgres on host):
# DATABASE_URL=postgres://kalkulation:kalkulation@localhost:5432/kalkulation
#
# Host pnpm + Dockerized DB from docker-compose.dev.yml (mapped to host 5433):
# DATABASE_URL=postgres://kalkulation:kalkulation@localhost:5433/kalkulation
#
# Full Docker stack (docker-compose.dev.yml sets this to host "db" automatically):
# DATABASE_URL=postgres://kalkulation:kalkulation@db:5432/kalkulation
