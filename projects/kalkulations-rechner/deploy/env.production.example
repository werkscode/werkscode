# Production environment — lives at ~/repositories/kalkulations-rechner/.env on the server.
# setup-server.sh / bootstrap-remote.sh create this with a generated password.

NUXT_HOST=0.0.0.0
NUXT_PORT=3000

POSTGRES_USER=kalkulation
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD
POSTGRES_DB=kalkulation

# Required by the app container (host must be "db" inside Docker):
DATABASE_URL=postgres://kalkulation:CHANGE_ME_STRONG_PASSWORD@db:5432/kalkulation

# Public demo: keep false so visitors use Pinia + localStorage (no DB for setup/quotes).
# The UI still saves in the browser. Server write APIs return 403.
# Set true only for a private/self-hosted instance with intentional DB writes.
# docker-compose.prod.yml forces false for the public subdomain deploy.
NUXT_PUBLIC_PERSISTENCE_ENABLED=false

# STEP converter (set automatically in docker-compose.prod.yml; override only if needed):
# NUXT_STEP_CONVERTER_URL=http://step-converter:8000
